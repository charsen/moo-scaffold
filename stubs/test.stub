use Illuminate\Support\Facades\Route;

it('{{controller}}：控制器类已生成且可加载', function () {
    // false = 控制器没生成 / 命名空间错 / 文件语法炸（autoload 不到）
    expect(class_exists('{{controller_fqcn}}'))->toBeTrue();
});

it('{{controller}}：路由已注册（codegen 把路由插进 routes 了）', function () {
    $routes = collect(Route::getRoutes()->getRoutes())
        ->filter(fn ($r) => str_starts_with((string) $r->getActionName(), '{{controller_fqcn}}@'));

    // 空 = 路由没插进去（routes/*.php 的 :insert_code_here 标记被删？控制器没挂上路由？）
    expect($routes)->not->toBeEmpty();
});
