# Playwright E2E 测试配置示例
# 复制到 .env 或设置为环境变量

# 宿主 Laravel 项目 URL（需要先启动服务）
E2E_BASE_URL=http://localhost

# Scaffold 认证账号（用于生成登录态）
E2E_USERNAME=admin
E2E_PASSWORD=your-password-here

# 宿主项目的 scaffold 目录（用于 safe 模式自动恢复 fixture）
# 例如: /Users/yourname/path/to/engine/scaffold
E2E_HOST_SCAFFOLD_DB_PATH=

# 可选：测试用的 schema 和 table（默认使用 engine 业务 schema）
# E2E_SCHEMA=Demo
# E2E_TABLE=demo_users
